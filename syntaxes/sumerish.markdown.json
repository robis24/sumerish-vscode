{
  "scopeName": "markdown.sumerish.codeblock",
  "injectionSelector": "L:text.html.markdown",
  "patterns": [
    {
      "include": "#sumerish-block"
    }
  ],
  "repository": {
    "sumerish-block": {
      "begin": "(^|\\G)(\\s*)(```|~~~)(\\s*sumerish\\s*)$",
      "beginCaptures": {
        "3": { "name": "punctuation.definition.fenced.markdown" },
        "4": { "name": "entity.name.language.sumerish" }
      },
      "end": "(^|\\G)(\\2)(\\3)\\s*$",
      "endCaptures": {
        "3": { "name": "punctuation.definition.fenced.markdown" }
      },
      "contentName": "meta.embedded.block.sumerish",
      "patterns": [
        { "include": "source.sumerish" }
      ]
    }
  }
}
